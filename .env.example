# ──────────────────────────────────────────────────
# AgentProof Environment Configuration
# Copy to .env and fill in your keys:
#   cp .env.example .env  (or:  Copy-Item .env.example .env)
# ──────────────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgresql+asyncpg://agentproof:agentproof@localhost:5432/agentproof
DATABASE_URL_SYNC=postgresql://agentproof:agentproof@localhost:5432/agentproof

# ── LLM API Keys ──
# Anthropic (for Claude judge model in eval engine)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OpenAI (for demo agent GPT-4o-mini + embeddings)
OPENAI_API_KEY=sk-your-key-here

# ── AgentProof Server ──
AGENTPROOF_SERVER_URL=http://localhost:8000
AGENTPROOF_PROJECT=demo-research-agent

# ── Dashboard ──
VITE_API_URL=http://localhost:8000

# ── Optional ──
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000